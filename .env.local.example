# =============================================================================
# Active Environment
# =============================================================================
# Controls which set of keys is used. One of: sandbox | staging | production
NEXT_PUBLIC_HITPAY_ENV=sandbox

# =============================================================================
# Stripe Keys (per environment)
# =============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_SANDBOX=pk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_STAGING=pk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_PRODUCTION=pk_live_xxx

STRIPE_SECRET_KEY_SANDBOX=sk_test_xxx
STRIPE_SECRET_KEY_STAGING=sk_test_xxx
STRIPE_SECRET_KEY_PRODUCTION=sk_live_xxx

# =============================================================================
# HitPay Keys (per environment)
# =============================================================================

HITPAY_API_KEY_SANDBOX=xxx
HITPAY_API_KEY_STAGING=xxx
HITPAY_API_KEY_PRODUCTION=xxx

HITPAY_SALT_SANDBOX=xxx
HITPAY_SALT_STAGING=xxx
HITPAY_SALT_PRODUCTION=xxx

# =============================================================================
# Custom Payment Methods
# =============================================================================
# CPM Type IDs are configured in /config/payment-methods.ts
# Edit that file to add/remove payment methods

# =============================================================================
# Subscription Products (Stripe Billing)
# =============================================================================
# Subscription products are fetched AUTOMATICALLY from your Stripe Dashboard!
# No configuration needed here - just create products with recurring prices
# in your Stripe Dashboard and they'll appear in the app.

# =============================================================================
# Webhook Configuration (for production)
# =============================================================================

# Your public site URL (used for webhook callbacks)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Stripe Webhook Secret (for verifying Stripe webhook signatures)
# Get this from Stripe Dashboard > Developers > Webhooks > Your endpoint > Signing secret
# Required for auto-charge subscription renewals via /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
