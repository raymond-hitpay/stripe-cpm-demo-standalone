# =============================================================================
# Stripe Configuration (Standard Account)
# =============================================================================

# Your Stripe publishable key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Your Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_xxx

# Custom Payment Method Type ID (created in your Stripe Dashboard)
# This is the cpmt_xxx ID for your PayNow custom payment method type
NEXT_PUBLIC_CPM_TYPE_ID=cpmt_xxx

# =============================================================================
# HitPay Configuration
# =============================================================================

# HitPay API Key (from your HitPay Dashboard)
HITPAY_API_KEY=xxx

# HitPay Salt (for webhook signature verification)
HITPAY_SALT=xxx

# HitPay Environment: 'sandbox' or 'production'
NEXT_PUBLIC_HITPAY_ENV=sandbox
