# =============================================================================
# Stripe Configuration (Standard Account)
# =============================================================================

# Your Stripe publishable key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Your Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_xxx

# =============================================================================
# Custom Payment Methods
# =============================================================================
# CPM Type IDs are configured in /config/payment-methods.ts
# Edit that file to add/remove payment methods

# =============================================================================
# HitPay Configuration
# =============================================================================

# HitPay API Key (from your HitPay Dashboard)
HITPAY_API_KEY=xxx

# HitPay Salt (for webhook signature verification)
HITPAY_SALT=xxx

# HitPay Environment: 'sandbox' or 'production'
NEXT_PUBLIC_HITPAY_ENV=sandbox

# =============================================================================
# Webhook Configuration (Optional - for production)
# =============================================================================

# Your public site URL (used for webhook callbacks)
# Set this to your production URL when deploying
NEXT_PUBLIC_SITE_URL=https://webhook.site/3d62840a-f9b3-4324-98f4-dc82d1c202a9
